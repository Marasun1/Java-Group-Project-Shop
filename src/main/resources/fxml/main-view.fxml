<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.store.controller.MainController">

    <top>
        <HBox spacing="12" styleClass="top-bar">
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Warehouse Management System" styleClass="app-title"/>
                        <Label text="Складський облік" styleClass="app-subtitle"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" styleClass="sidebar">
            <padding>
                <Insets top="18" right="12" bottom="18" left="12"/>
            </padding>
            <children>
                <Label text="Меню" styleClass="sidebar-title"/>

                <Button text="Товари" prefWidth="160" styleClass="nav-button" id="activeNavButton"/>
                <Button text="Залишки" prefWidth="160" styleClass="nav-button"/>
                <Button text="Надходження" prefWidth="160" styleClass="nav-button"/>
                <Button text="Ціни" prefWidth="160" styleClass="nav-button"/>
                <Button text="Користувачі" prefWidth="160" styleClass="nav-button"/>
                <Button text="Налаштування" prefWidth="160" styleClass="nav-button"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="16" styleClass="content-area">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <children>
                <HBox spacing="12">
                    <children>
                        <Label text="Товари" styleClass="page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Оновити" onAction="#handleRefresh" styleClass="secondary-button"/>
                    </children>
                </HBox>

                <SplitPane dividerPositions="0.68" VBox.vgrow="ALWAYS">
                    <items>
                        <VBox spacing="12" styleClass="content-card">
                            <children>
                                <Label text="Список товарів" styleClass="section-title"/>

                                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                                        <TableColumn fx:id="skuColumn" text="SKU" prefWidth="140.0"/>
                                        <TableColumn fx:id="nameColumn" text="Назва" prefWidth="220.0"/>
                                        <TableColumn fx:id="descriptionColumn" text="Опис" prefWidth="280.0"/>
                                        <TableColumn fx:id="createdAtColumn" text="Створено" prefWidth="160.0"/>
                                        <TableColumn fx:id="updatedAtColumn" text="Оновлено" prefWidth="160.0"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="12" styleClass="content-card">
                            <children>
                                <Label text="Додати / редагувати товар" styleClass="section-title"/>

                                <Label text="SKU"/>
                                <TextField fx:id="skuField" promptText="Наприклад: SKU-101"/>

                                <Label text="Назва"/>
                                <TextField fx:id="nameField" promptText="Назва товару"/>

                                <Label text="Опис"/>
                                <TextArea fx:id="descriptionArea"
                                          promptText="Короткий опис товару"
                                          prefRowCount="6"
                                          wrapText="true"/>

                                <HBox spacing="10">
                                    <children>
                                        <Button text="Зберегти"
                                                onAction="#handleSave"
                                                styleClass="primary-button"/>
                                        <Button text="Очистити"
                                                onAction="#handleClear"
                                                styleClass="secondary-button"/>
                                        <Button text="Видалити"
                                                onAction="#handleDelete"
                                                styleClass="danger-button"/>
                                    </children>
                                </HBox>

                                <Label fx:id="statusLabel" text="Статус" styleClass="status-label"/>
                            </children>
                        </VBox>
                    </items>
                </SplitPane>
            </children>
        </VBox>
    </center>

</BorderPane>