<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.store.controller.MainController">

    <top>
        <HBox spacing="12" styleClass="top-bar">
            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="Warehouse Management System" styleClass="app-title"/>
                        <Label text="Складський облік" styleClass="app-subtitle"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" styleClass="sidebar">
            <padding>
                <Insets top="18" right="12" bottom="18" left="12"/>
            </padding>
            <children>
                <Label text="Меню" styleClass="sidebar-title"/>

                <Button fx:id="productsButton" text="Товари" prefWidth="160"
                        onAction="#showProducts" styleClass="nav-button"/>
                <Button fx:id="quantitiesButton" text="Залишки" prefWidth="160"
                        onAction="#showQuantities" styleClass="nav-button"/>
                <Button fx:id="receiptsButton" text="Надходження" prefWidth="160"
                        onAction="#showReceipts" styleClass="nav-button"/>
                <Button fx:id="pricesButton" text="Ціни" prefWidth="160"
                        onAction="#showPrices" styleClass="nav-button"/>
                <Button fx:id="usersButton" text="Користувачі" prefWidth="160"
                        onAction="#showUsers" styleClass="nav-button"/>
            </children>
        </VBox>
    </left>

</BorderPane>
