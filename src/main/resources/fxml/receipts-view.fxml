<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="content-area"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.store.controller.ReceiptsController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <HBox spacing="12">
            <children>
                <Label text="Надходження" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Оновити" onAction="#handleRefresh" styleClass="secondary-button"/>
            </children>
        </HBox>

        <SplitPane dividerPositions="0.68" VBox.vgrow="ALWAYS">
            <items>
                <VBox spacing="12" styleClass="content-card">
                    <children>
                        <Label text="Історія надходжень" styleClass="section-title"/>

                        <TableView fx:id="receiptTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                                <TableColumn fx:id="productIdColumn" text="Товар ID" prefWidth="110.0"/>
                                <TableColumn fx:id="userIdColumn" text="Користувач ID" prefWidth="130.0"/>
                                <TableColumn fx:id="qtyReceivedColumn" text="Кількість" prefWidth="120.0"/>
                                <TableColumn fx:id="wholesalePriceColumn" text="Гуртова ціна" prefWidth="140.0"/>
                                <TableColumn fx:id="receivedAtColumn" text="Отримано" prefWidth="180.0"/>
                                <TableColumn fx:id="noteColumn" text="Примітка" prefWidth="220.0"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="12" styleClass="content-card">
                    <children>
                        <Label text="Нове надходження" styleClass="section-title"/>

                        <Label text="Товар ID"/>
                        <TextField fx:id="productIdField" promptText="Наприклад: 1"/>

                        <Label text="Користувач ID"/>
                        <TextField fx:id="userIdField" promptText="Наприклад: 1"/>

                        <Label text="Кількість"/>
                        <TextField fx:id="qtyReceivedField" promptText="10"/>

                        <Label text="Локація"/>
                        <TextField fx:id="locationField" promptText="Склад A, полиця 3"/>

                        <Label text="Гуртова ціна"/>
                        <TextField fx:id="wholesalePriceField" promptText="100.00"/>

                        <Label text="Примітка"/>
                        <TextArea fx:id="noteArea" promptText="Деталі надходження" prefRowCount="4" wrapText="true"/>

                        <HBox spacing="10">
                            <children>
                                <Button text="Зберегти" onAction="#handleSave" styleClass="primary-button"/>
                                <Button text="Очистити" onAction="#handleClear" styleClass="secondary-button"/>
                                <Button text="Видалити" onAction="#handleDelete" styleClass="danger-button"/>
                            </children>
                        </HBox>

                        <Label fx:id="statusLabel" text="Статус" styleClass="status-label"/>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </children>
</VBox>
