<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="content-area"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.store.controller.ReceiptsController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <HBox spacing="12">
            <children>
                <Label text="Надходження" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Оновити" onAction="#handleRefresh" styleClass="secondary-button"/>
            </children>
        </HBox>

        <SplitPane dividerPositions="0.73" VBox.vgrow="ALWAYS">
            <items>
                <VBox spacing="12" styleClass="content-card">
                    <children>
                        <Label text="Історія надходжень" styleClass="section-title"/>

                        <TableView fx:id="receiptTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0"/>
                                <TableColumn fx:id="productIdColumn" text="Товар ID" prefWidth="90.0"/>
                                <TableColumn fx:id="userIdColumn" text="Користувач ID" prefWidth="110.0"/>
                                <TableColumn fx:id="roleIdColumn" text="Роль ID" prefWidth="80.0"/>
                                <TableColumn fx:id="supplierColumn" text="Постачальник" prefWidth="150.0"/>
                                <TableColumn fx:id="qtyReceivedColumn" text="Кількість" prefWidth="100.0"/>
                                <TableColumn fx:id="costPriceColumn" text="Собівартість" prefWidth="120.0"/>
                                <TableColumn fx:id="expiresAtColumn" text="Придатний до" prefWidth="120.0"/>
                                <TableColumn fx:id="receivedAtColumn" text="Отримано" prefWidth="160.0"/>
                                <TableColumn fx:id="noteColumn" text="Примітка" prefWidth="160.0"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="form-scroll">
                    <content>
                        <VBox spacing="12" styleClass="content-card">
                            <children>
                                <Label text="Нове надходження" styleClass="section-title"/>

                                <Label text="Товар ID"/>
                                <TextField fx:id="productIdField" promptText="Наприклад: 1"/>

                                <Label text="Користувач ID"/>
                                <TextField fx:id="userIdField" promptText="Наприклад: 1"/>

                                <Label text="Роль"/>
                                <ComboBox fx:id="roleComboBox" promptText="Обери роль"/>

                                <Label text="Постачальник"/>
                                <TextField fx:id="supplierField" promptText="Назва постачальника"/>

                                <Label text="Номер накладної"/>
                                <TextField fx:id="invoiceNumberField" promptText="Необов'язково"/>

                                <Label text="Кількість"/>
                                <TextField fx:id="qtyReceivedField" promptText="10.000"/>

                                <Label text="Локація"/>
                                <ComboBox fx:id="locationComboBox" promptText="Обери локацію"/>

                                <Label text="Собівартість"/>
                                <TextField fx:id="costPriceField" promptText="100.00"/>

                                <Label text="Придатний до"/>
                                <TextField fx:id="expiresAtField" promptText="дд.ММ.рррр, необов'язково"/>

                                <Label text="Примітка"/>
                                <TextArea fx:id="noteArea" promptText="Деталі надходження" prefRowCount="3" wrapText="true"/>

                                <HBox spacing="10">
                                    <children>
                                        <Button text="Зберегти" onAction="#handleSave" styleClass="primary-button"/>
                                        <Button text="Очистити" onAction="#handleClear" styleClass="secondary-button"/>
                                        <Button text="Видалити" onAction="#handleDelete" styleClass="danger-button"/>
                                    </children>
                                </HBox>

                                <Label fx:id="statusLabel" text="Статус" styleClass="status-label"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>
    </children>
</VBox>
