<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="content-area"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.store.controller.QuantitiesController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <HBox spacing="12">
            <children>
                <Label text="Залишки" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Оновити" onAction="#handleRefresh" styleClass="secondary-button"/>
            </children>
        </HBox>

        <SplitPane dividerPositions="0.68" VBox.vgrow="ALWAYS">
            <items>
                <VBox spacing="12" styleClass="content-card">
                    <children>
                        <Label text="Залишки товарів" styleClass="section-title"/>

                        <TableView fx:id="quantityTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
                                <TableColumn fx:id="productIdColumn" text="Товар ID" prefWidth="110.0"/>
                                <TableColumn fx:id="locationColumn" text="Локація" prefWidth="220.0"/>
                                <TableColumn fx:id="qtyColumn" text="Кількість" prefWidth="130.0"/>
                                <TableColumn fx:id="lastUpdatedColumn" text="Оновлено" prefWidth="180.0"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="12" styleClass="content-card">
                    <children>
                        <Label text="Додати / редагувати залишок" styleClass="section-title"/>

                        <Label text="Товар ID"/>
                        <TextField fx:id="productIdField" promptText="Наприклад: 1"/>

                        <Label text="Локація"/>
                        <TextField fx:id="locationField" promptText="Склад A, полиця 3"/>

                        <Label text="Кількість"/>
                        <TextField fx:id="qtyField" promptText="0"/>

                        <HBox spacing="10">
                            <children>
                                <Button text="Зберегти" onAction="#handleSave" styleClass="primary-button"/>
                                <Button text="Очистити" onAction="#handleClear" styleClass="secondary-button"/>
                                <Button text="Видалити" onAction="#handleDelete" styleClass="danger-button"/>
                            </children>
                        </HBox>

                        <Label fx:id="statusLabel" text="Статус" styleClass="status-label"/>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </children>
</VBox>
